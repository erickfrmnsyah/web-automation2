{
    "name": "Web Automation",
    "version": "2.0.0",
    "description": "Selenium WebDriver tests using Mocha with Mochawesome reports",
    "scripts": {
        "tests": "mocha test --recursive --timeout 60000 --reporter mochawesome --reporter-options reportDir=reports,overwrite=true,html=true,json=true",
        "test": "mocha test --recursive --timeout 60000"
    },
    "dependencies": {
        "dotenv": "^17.4.2",
        "pixelmatch": "^7.2.0",
        "pngjs": "^7.0.0",
        "selenium-webdriver": "^4.17.0"
    },
    "devDependencies": {
        "mocha": "^10.4.0",
        "mocha-simple-html-reporter": "^2.0.0",
        "mochawesome": "^7.1.3"
    }
}
